{
  "name": "flow-sample",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "flow-typed install --skip",
    "dev": "pnpm build && concurrently -k \"nodemon --watch src --ext js,html,css --exec 'pnpm run build'\" \"live-server dist --port=3000\"",
    "flow": "flow",
    "check": "flow check",
    "build": "babel src --out-dir dist && postcss src/css/input.css -o dist/css/style.css && cp src/index.html dist/index.html",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@babel/cli": "^8.0.4",
    "@babel/core": "^8.0.1",
    "@babel/preset-flow": "^8.0.1",
    "@tailwindcss/postcss": "^4.3.2",
    "autoprefixer": "^10.5.2",
    "concurrently": "^10.0.3",
    "flow-bin": "^0.322.0",
    "flow-typed": "^4.1.1",
    "live-server": "^1.2.2",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.19",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^4.3.2"
  }
}
